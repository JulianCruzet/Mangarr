# Mangarr Backend Configuration

# Data directory: SQLite DB is stored here as mangarr.db (covers live here too).
DATA_DIR=./data

# Advanced only: override database connection (omit in normal setups).
# DATABASE_URL=sqlite:////absolute/path/to/mangarr.db

# Server host and port
HOST=0.0.0.0
PORT=8000

# CORS allowed origins (comma-separated list in JSON format)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Default language for chapter fetching
DEFAULT_LANGUAGE=en

# Naming templates
SERIES_FOLDER_FORMAT={Series Title} ({Year})
FILE_FORMAT={Series Title} - Vol.{Volume} Ch.{Chapter} - {Chapter Title}{Extension}
FILE_FORMAT_NO_VOLUME={Series Title} - Ch.{Chapter} - {Chapter Title}{Extension}

# Supported manga file extensions (JSON list)
MANGA_EXTENSIONS=[".cbz",".cbr",".zip",".pdf",".epub"]
